<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChatNode</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="style.css">
</head>
<body class="bg-light">
  <div class="container mt-4">
    <h3 class="text-center mb-4 text-primary">ChatNode</h3>
    <div class="text-center mb-4">
        <a href="/chats/new" class="btn btn-primary">Add New Chat</a>
    </div>

    <div class="row">
      <% for(let chat of chats) { %>
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h6 class="card-subtitle mb-2 text-muted">From: <b><%=chat.from%></b></h6>
              <div class="msg-bubble-blue">
                <%=chat.msg%>
              </div>
              <p class="card-text">To: <b><%=chat.to%></b></p>
              
              <div class="d-flex gap-2 mt-2">
                <a href="/chats/<%=chat._id%>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                <form method="POST" action="/chats/<%=chat._id%>?_method=DELETE">
                  <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </div>
            </div>
            <div class="card-footer text-muted small">
              <%=chat.created_at.toString().slice(0,16)%>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</body>

</html>