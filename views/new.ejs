<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChatNode</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="style.css">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0 text-center">New Chat</h4>
                    </div>
                    <div class="card-body p-4">
                        <form method="POST" action="/chats">
                            <div class="mb-3">
                                <label for="from" class="form-label">Sender Name</label>
                                <input type="text" class="form-control" id="from" placeholder="Who are you?" name="from" required>
                            </div>
                            
                            <div class="mb-3">
                                <label for="to" class="form-label">Receiver Name</label>
                                <input type="text" class="form-control" id="to" placeholder="Who is this for?" name="to" required>
                            </div>

                            <div class="mb-3">
                                <label for="msg" class="form-label">Message</label>
                                <textarea class="form-control" id="msg" placeholder="Write your message here..." name="msg" rows="3" required></textarea>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button class="btn btn-success">Send Message</button>
                                <a href="/chats" class="btn btn-outline-secondary">Back to All Chats</a>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
