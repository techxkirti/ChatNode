<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Chat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 border rounded py-4 bg-white shadow-sm">
                <div class="card-header bg-primary text-white p-2">
                    <h3 class="text-center mb-0">Edit Your Chat</h3>
                </div>

                <p class="text-muted small text-center">ID: <%=chat._id%></p>
                
                <div class="alert alert-light border-info py-2">
                    Editing message from <strong><%=chat.from%></strong> to <strong><%=chat.to%></strong>
                </div>

                <form method="POST" action="/chats/<%=chat._id%>?_method=PUT">
                    <div class="mb-3">
                        <label for="msg" class="form-label">Message Content</label>
                        <textarea 
                            class="form-control" 
                            id="msg" 
                            name="msg" 
                            rows="5"
                        ><%=chat.msg%></textarea>
                    </div>
                    
                    <div class="d-flex gap-2 justify-content-center gap-3">
                        <button class="btn btn-primary px-4">Save Changes</button>
                        <a href="/chats" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
